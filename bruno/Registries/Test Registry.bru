meta {
  name: Test Registry
  type: http
  seq: 34
}

post {
  url: {{baseUrl}}/api/v1/registries/test
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "server": "ghcr.io",
    "username": "REPLACE_WITH_USERNAME",
    "password": "REPLACE_WITH_TOKEN"
  }
}

docs {
  Validates the credentials by performing a registry login through the local
  Docker daemon (the host running Rivly). Returns 200 on success, 502 if the
  credentials are rejected.
}
