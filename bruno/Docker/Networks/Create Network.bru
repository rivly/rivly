meta {
  name: Create Network
  type: http
  seq: 27
}

post {
  url: {{baseUrl}}/api/v1/environments/1/networks
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "name": "app_net",
    "driver": "bridge",
    "subnet": "172.20.0.0/16"
  }
}

assert {
  res.status: eq 201
}
