meta {
  name: Network Actions
  type: http
  seq: 20
}

post {
  url: {{baseUrl}}/api/v1/environments/1/networks/actions
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "action": "remove",
    "ids": ["REPLACE_WITH_NETWORK_ID"]
  }
}

assert {
  res.status: eq 200
}
