meta {
  name: Add Git Credential
  type: http
  seq: 36
}

post {
  url: {{baseUrl}}/api/v1/git-credentials
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "name": "GitHub - acme",
    "username": "REPLACE_WITH_USERNAME",
    "token": "REPLACE_WITH_TOKEN"
  }
}

assert {
  res.status: eq 201
}
